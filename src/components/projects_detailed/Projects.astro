---
import type { CollectionEntry } from "astro:content";
import { compareProjectsByDateOrYearDesc, formatProjectDateOrYear } from "../../utils/projectDate";

const K = 2; // Number of recent posts to display

const projects = (Astro.props.projects ?? []) as CollectionEntry<"projects">[];

const allProjects = projects
  .sort((a, b) => compareProjectsByDateOrYearDesc(a.data, b.data))
  .slice(0, K);
---

<div class="flex flex-col lg:flex-row justify-evenly">
  <header class="mb-8">
    <h1 class="mb-2">Recent Projects from the Blog</h1>
    <h2 class="mb-4 text-text dark:text-dk-text">Expect more projects from me!</h2>
  </header>
  <div>
    {
      allProjects.map((project) => (
        <div class="mb-8">
          <h1 class="mb-2">
            <a href={`/projects/${project.slug}`}>{project.data.title}</a>
          </h1>
          <p>{project.data.description}</p>
          <p class="text-gray-600 dark:text-gray-400">
            {formatProjectDateOrYear(project.data)}
          </p>
          <a
            class="text-secondary dark:text-dk-secondary hover:text-accent dark:hover:text-dk-accent"
            href={`/projects/${project.slug}`}
          >
            Read more &rarr;
          </a>
          <div class="border-t border-gray-200 dark:border-dk-gray-800 my-8" />
        </div>
      ))
    }
    <div class="text-right mt-4 text-secondary dark:text-dk-secondary">
      <a class="hover:text-accent dark:hover:text-dk-accent" href="/projects">
        Read more projects</a
      >
    </div>
  </div>
</div>
